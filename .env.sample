WEB_PORT=9004
PHP_MYADMIN_PORT=9094
MYSQL_ROOT_PASSWORD=your_mysql_root_password
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
API_PORT=3004
network=mirror-network

# WordPress JWT Auth: secret key used by WordPress (wp-config.php) to sign/verify tokens
JWT_AUTH_SECRET_KEY=your_jwt_secret_key_here

# WordPress JWT token for FastAPI to call the WordPress REST API
# Get from WP JWT Auth UI or POST /wp-json/jwt-auth/v1/token
WORDPRESS_JWT_TOKEN=your_wordpress_jwt_token_here
WORDPRESS_JWT_USER=your_wordpress_jwt_user
WORDPRESS_JWT_PASSWORD=your_wordpress_jwt_password

GIT_USER_EMAIL=you@example.com
GIT_USER_NAME=your_github_username

# AI API keys
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database
DATABASE_URL=sqlite:///fr-mirror.db

# Typesense (docker service `typesense`; from other containers use http://typesense:8108)
TYPESENSE_API_KEY=your_typesense_api_key_here
# Production only: hostname for Caddy HTTPS in front of Typesense (no scheme, no port). DNS A/AAAA → server. WordPress Customizer should use https://<this-host> for browser search.
# After deploy: curl -sS "https://<TYPESENSE_SEARCH_HOST>/health" should return {"ok":true}
TYPESENSE_SEARCH_HOST=167.71.90.20
#YOUTUBE_COOKIES_PATH=/code/youtube_cookies.txt
WEBSHARE_PROXY_USERNAME=enter-user
WEBSHARE_PROXY_PASSWORD=enter-password
DEFAULT_YOUTUBE_CHANNEL_URL=https://www.youtube.com/@FallRiverGovernmentTV/videos
XAI_API_KEY=enter-api-key

# Webshare proxy (used for YouTube transcript fetching)
WEBSHARE_PROXY_USERNAME=your_proxy_username
WEBSHARE_PROXY_PASSWORD=your_proxy_password
WEBSHARE_PROXY_HOST=your_proxy_host

# YouTube
DEFAULT_YOUTUBE_CHANNEL_URL=https://www.youtube.com/@YourChannel/videos
YOUTUBE_COOKIES_PATH=/code/youtube_cookies.txt

# YouTube OAuth 2.0 credentials (required for transcript fetching)
YOUTUBE_OAUTH_CREDENTIALS_PATH=/code/client_secret.json
YOUTUBE_OAUTH_TOKEN_PATH=youtube_token.json

# GCP service account key file path (AS3CF / offload media)
GCP_KEY_FILE_PATH=/code/your-gcp-key-file.json

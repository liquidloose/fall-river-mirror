# Sample environment configuration for the Fall River Mirror app.
#
# Copy this file to ``.env`` and fill in the values. The real ``.env`` is
# gitignored. Only API keys live here; model identifiers are typed enums

# --- Local dev (fr-mirror-ai) ------------------------------------------------
# Hot-reload Python on file changes. Leave unset or 0 in production.
UVICORN_RELOAD=1
# Keep app logs outside /code so --reload does not restart on log writes.
APP_LOG_PATH=/tmp/fr-mirror-app.log

# in ``app/data/enum_classes.py`` (GeminiModel / XaiModel / AnthropicModel)
# selected per-call, not via environment variables.

# --- LLM provider API keys -------------------------------------------------

# xAI Grok API key. Used by FRJ1 (journalist), Aurelius Stone (journalist),
# Spectra Veritas (artist), and the editor / fact-checker agents.
# https://docs.x.ai
XAI_API_KEY=

# Anthropic Claude API key. Used when an agent is constructed with
# ``provider=TextLLMProvider.ANTHROPIC``.
# https://platform.claude.com
ANTHROPIC_API_KEY=

# Google Gemini API key. Used by all extractors (Gemma Nye and any future
# extractor that inherits BaseExtractor), which are pinned to Gemini via
# ``BaseExtractor.PROVIDER``.
# https://ai.google.dev
GEMINI_API_KEY=

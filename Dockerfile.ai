FROM python:3.12-bookworm

# Install FFmpeg for audio processing
RUN apt-get update && apt-get install -y ffmpeg sqlite3 git xvfb curl unzip && rm -rf /var/lib/apt/lists/*

# Install Deno (required for yt-dlp YouTube extraction - solves JS challenges)
RUN curl -fsSL https://deno.land/install.sh | sh
ENV DENO_INSTALL="/root/.deno"
ENV PATH="${DENO_INSTALL}/bin:${PATH}"

WORKDIR /code

# Copy requirements first for better caching
COPY ./requirements.txt /code/requirements.txt

# Install Python packages
RUN pip install --no-cache-dir --upgrade pip
RUN pip install --no-cache-dir -r /code/requirements.txt

# Install Playwright system dependencies and browsers
RUN playwright install-deps
RUN playwright install chromium

# Configure git for the working directory
RUN git config --global --add safe.directory /code

# Copy entrypoint script
COPY ./entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Set DISPLAY environment variable
ENV DISPLAY=:99

# Copy the app code
COPY ./app /code/app

# Use entrypoint to start Xvfb before the app
ENTRYPOINT ["/entrypoint.sh"]
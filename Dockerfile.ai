FROM python:3.12-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install system packages with minimal footprint.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg sqlite3 git xvfb curl unzip gosu \
    && rm -rf /var/lib/apt/lists/*

# Install Deno (required for yt-dlp YouTube extraction - solves JS challenges)
# Install system-wide into /usr/local/bin so all users (including app:1000) can access it.
RUN curl -fsSL https://deno.land/install.sh | DENO_INSTALL=/usr/local sh -s -- -q

WORKDIR /code

# Copy requirements first for better caching
COPY ./requirements.txt /code/requirements.txt

# Install Python packages in one layer.
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r /code/requirements.txt

# Install Playwright system dependencies and Chromium in one layer.
RUN playwright install-deps \
    && playwright install chromium

# Create app user with UID/GID 1000 to match host (same pattern as WordPress Dockerfile)
RUN groupadd -g 1000 app && useradd -m -u 1000 -g 1000 app

# Configure git for the working directory
RUN git config --global --add safe.directory /code

# Copy entrypoint script and app code
COPY ./entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
COPY ./app /code/app

# Own /code and runtime dirs (Deno, Playwright) by app so process can run as 1000:1000
RUN chown -R app:app /code \
    && chown -R app:app /root/.cache/ms-playwright

# App user will use Playwright browsers from this path
ENV PLAYWRIGHT_BROWSERS_PATH=/root/.cache/ms-playwright
ENV DISPLAY=:99

ENTRYPOINT ["/entrypoint.sh"]
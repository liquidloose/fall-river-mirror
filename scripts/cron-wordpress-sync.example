# Host crontab: run pipeline for 2 articles and sync to WordPress every 15 minutes.
# Paste ONLY the line below into crontab -e. Change the URL if your API is elsewhere.
# Log path is in the project dir so you don't need /var/log write permission.
# In crontab, % must be written as \% (cron treats % as newline otherwise).
*/15 * * * * sh -c 'CODE=$(curl -s -o /dev/null -w "\%{http_code}" -X POST "http://localhost:3004/pipeline/run?amount=2&auto_build=true&journalist=FRJ1&tone=professional&article_type=news&model=gpt-image-1&sync_to_wordpress=true" -H "accept: application/json" -d ""); if [ "${CODE#2}" != "$CODE" ]; then echo "$(date) complete" >> /home/ron/development/fall-river-mirror/pipeline-wordpress.log; else echo "$(date) failed HTTP $CODE" >> /home/ron/development/fall-river-mirror/pipeline-wordpress.log; fi'

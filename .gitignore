.env
.env.dev
.env.production

# Google OAuth credentials (sensitive)
client_secret.json
youtube_token.json
youtube_cookies.txt
cookies.txt

# GCP service account key (private key; path set via GCP_KEY_FILE_PATH in .env)
the-fall-river-mirror-mailer-*.json

# Ignore everything in WordPress except the fall-river-mirror theme
/WordPress/*
!/WordPress/wp-content/
/WordPress/wp-content/*
!/WordPress/wp-content/themes/
/WordPress/wp-content/themes/*
!/WordPress/wp-content/themes/fall-river-mirror-theme/
# fall-river-mirror-theme is a submodule; track it only in its own repo (ignore working tree contents here)

# Explicitly ignore plugins and other directories
/WordPress/wp-content/plugins/
# Plugin submodules; track in their own repos only
/WordPress/wp-content/plugins/to-tha-top/
/WordPress/wp-content/plugins/dark-and-light/
/WordPress/wp-content/uploads/
/WordPress/wp-content/cache/
/WordPress/wp-content/backup-db/
/WordPress/wp-content/backups/
/WordPress/wp-content/blogs.dir/
/WordPress/wp-content/upgrade/
/WordPress/wp-content/uploads/
/WordPress/wp-content/advanced-cache.php
/WordPress/wp-content/wp-cache-config.php
/WordPress/wp-content/plugins/hello.php

# Ignore default WordPress themes
/WordPress/wp-content/themes/twentytwentyfive/
/WordPress/wp-content/themes/twentytwentyfour/
/WordPress/wp-content/themes/twentytwentythree/
asdf
# Python cache files
__pycache__/
/vendor/*

# Typesense bind-mounted data (docker-compose)
typesense-data/

/app/data/fr-mirror.db
app.log

# YouTube OAuth credentials and tokens (contains sensitive credentials)
client_secret.json
youtube_oauth_token.json
youtube_token.json
*_token.json